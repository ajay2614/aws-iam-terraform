# Advanced example: create multiple IAM users, groups, and policy attachments using for_each.
# This file is NOT used by default. It's a reference for more complex patterns.

terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

# Example inputs (define in terraform.tfvars or pass with -var-file):
# users = ["alice", "bob"]
# groups = ["devops", "data"]
# group_memberships = {
#   devops = ["alice"]
#   data   = ["bob", "alice"]
# }
# attach_s3_readonly_to_groups = ["devops"]

variable "users" {
  type        = list(string)
  description = "List of IAM users to create."
  default     = []
}

variable "groups" {
  type        = list(string)
  description = "List of IAM groups to create."
  default     = []
}

variable "group_memberships" {
  type        = map(list(string))
  description = "Group -> list of user names to add."
  default     = {}
}

variable "attach_s3_readonly_to_groups" {
  type        = list(string)
  description = "List of group names that should get AmazonS3ReadOnlyAccess."
  default     = []
}

resource "aws_iam_user" "user" {
  for_each = toset(var.users)
  name     = each.value
}

resource "aws_iam_group" "group" {
  for_each = toset(var.groups)
  name     = each.value
}

# Build group memberships from the map.
# Each membership resource manages one group and its user list.
resource "aws_iam_group_membership" "membership" {
  for_each = var.group_memberships

  name  = "${each.key}-membership"
  group = aws_iam_group.group[each.key].name

  # Only include users that exist in var.users.
  users = [
    for u in each.value : aws_iam_user.user[u].name
    if contains(var.users, u)
  ]
}

data "aws_iam_policy" "s3_read_only" {
  arn = "arn:aws:iam::aws:policy/AmazonS3ReadOnlyAccess"
}

resource "aws_iam_group_policy_attachment" "s3_read_only" {
  for_each = toset(var.attach_s3_readonly_to_groups)

  group      = aws_iam_group.group[each.value].name
  policy_arn = data.aws_iam_policy.s3_read_only.arn
}
